# ============================================================
# S-Matrix 环境变量配置示例
# 复制本文件为 .env，填入实际值后运行 docker-compose up -d
# ============================================================

# ------------------------------------------------------------
# LLM 配置（必填其一）
# 支持 DeepSeek / OpenAI / 通义千问等 OpenAI-compatible API
# ------------------------------------------------------------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ------------------------------------------------------------
# API 认证密钥（必填）
# 所有 /api/* 接口请求必须在 Header 携带此 Key：
#   X-API-Key: <your-key>
#   或 Authorization: Bearer <your-key>
# 可使用任意随机字符串，例如：openssl rand -hex 32
# ------------------------------------------------------------
SMATRIX_API_KEY=

# ------------------------------------------------------------
# 数据源密码加密密钥（使用数据源同步功能时必填）
# 用于加密存储在 Doris 中的外部数据库密码
# 未设置时每次重启会生成随机密钥，导致已存储密码无法解密
# 生成方式：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ------------------------------------------------------------
ENCRYPTION_KEY=

# ------------------------------------------------------------
# CORS 配置（可选）
# 允许访问 API 的前端地址，多个用逗号分隔
# ------------------------------------------------------------
SMATRIX_CORS_ORIGINS=http://localhost:35173
